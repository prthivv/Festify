<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CEFMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/public/styles.css" />
  </head>
  <body>
    <main class="app-shell">
      <div class="container">
        <section class="hero-card fade-up mb-4">
          <span class="eyebrow">Festify / CEFMS</span>
          <div class="row align-items-end g-4 mt-1">
            <div class="col-lg-8">
              <h1 class="display-title">Plan, run, and track college fests in one place.</h1>
              <p class="hero-copy">
                This starter dashboard is wired to the Express API and PostgreSQL schema. Use it to test
                login, browse events, view schedules, and confirm published results.
              </p>
            </div>
            <div class="col-lg-4">
              <div class="metric-grid">
                <div class="metric-tile">
                  <div class="metric-label">Events</div>
                  <div class="metric-value" id="totalEvents">0</div>
                </div>
                <div class="metric-tile">
                  <div class="metric-label">Schedules</div>
                  <div class="metric-value" id="totalSchedules">0</div>
                </div>
                <div class="metric-tile">
                  <div class="metric-label">Results</div>
                  <div class="metric-value" id="totalResults">0</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <div class="row g-4">
          <div class="col-lg-4 fade-up">
            <section class="panel-card h-100">
              <h2 class="section-title">Demo Login</h2>
              <form id="loginForm" class="d-grid gap-3">
                <div>
                  <label class="form-label" for="email">Email</label>
                  <input
                    class="form-control"
                    id="email"
                    name="email"
                    type="email"
                    placeholder="admin@cefms.edu"
                    required
                  />
                </div>
                <div>
                  <label class="form-label" for="password">Password</label>
                  <input
                    class="form-control"
                    id="password"
                    name="password"
                    type="password"
                    placeholder="correct horse battery staple"
                    required
                  />
                </div>
                <button class="btn btn-brand" type="submit">Sign In</button>
                <p class="muted-note mb-0">
                  All seeded accounts share the demo password:
                  <code>correct horse battery staple</code>
                </p>
                <div id="loginMessage" class="small mt-2"></div>
              </form>
            </section>
          </div>

          <div class="col-lg-8 fade-up">
            <section id="sessionPanel" class="panel-card hidden h-100">
              <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                  <h2 class="section-title mb-2">Active Session</h2>
                  <div class="status-pill mb-3">Session live</div>
                  <p class="mb-1"><strong id="sessionName">-</strong></p>
                  <p class="mb-1 muted-note" id="sessionRole">-</p>
                  <p class="mb-0 muted-note" id="sessionEmail">-</p>
                </div>
                <button id="logoutButton" class="btn btn-ghost" type="button">Log Out</button>
              </div>
            </section>
          </div>
        </div>

        <div class="row g-4 mt-1">
          <div class="col-12 fade-up">
            <section class="table-card">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="section-title mb-0">Events</h2>
                <span class="muted-note">Live API data</span>
              </div>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead>
                    <tr>
                      <th>Event</th>
                      <th>Coordinator</th>
                      <th>Capacity</th>
                      <th>Venue</th>
                    </tr>
                  </thead>
                  <tbody id="eventsBody"></tbody>
                </table>
              </div>
            </section>
          </div>

          <div class="col-lg-7 fade-up">
            <section class="table-card h-100">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="section-title mb-0">Schedule Board</h2>
                <span class="muted-note">Venue + timing</span>
              </div>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead>
                    <tr>
                      <th>Event</th>
                      <th>Venue</th>
                      <th>Starts</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody id="scheduleBody"></tbody>
                </table>
              </div>
            </section>
          </div>

          <div class="col-lg-5 fade-up">
            <section class="table-card h-100">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="section-title mb-0">Published Results</h2>
                <span class="muted-note">Completed events</span>
              </div>
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead>
                    <tr>
                      <th>Event</th>
                      <th>Winner</th>
                      <th>Published</th>
                    </tr>
                  </thead>
                  <tbody id="resultsBody"></tbody>
                </table>
              </div>
            </section>
          </div>
        </div>
      </div>
    </main>

    <script src="/public/app.js"></script>
  </body>
</html>
